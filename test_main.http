# ======================================================
# PHASE4: QA 文件上传入库测试（txt/md/pdf/docx）
# 用途：验证大文件解析切块后自动入库
# 注意：将 ./fixtures/sample.txt 替换为你本地实际文件路径
# ======================================================
POST http://127.0.0.1:8000/api/v1/qa/ingest-file
Content-Type: multipart/form-data; boundary=WebAppBoundary
Accept: application/json

--WebAppBoundary
Content-Disposition: form-data; name="document_id"

doc-upload-001
--WebAppBoundary
Content-Disposition: form-data; name="source_uri"

file://local/sample.txt
--WebAppBoundary
Content-Disposition: form-data; name="file"; filename="sample.txt"
Content-Type: text/plain

< ./fixtures/sample.txt
--WebAppBoundary--

###

# ======================================================
# PHASE5: Grading Agent 批改测试
# 用途：验证客观题规则判分 + 主观题/编程题 LLM 判分 + 学情分析输出
# ======================================================
POST http://127.0.0.1:8000/api/v1/grading/grade
Content-Type: application/json
Accept: application/json

{
  "exam_id": "exam-001",
  "student_id": "stu-001",
  "teacher_id": "teacher-001",
  "questions": [
    {
      "question_id": "q-obj-1",
      "question_type": "objective",
      "stem": "HTTP 默认端口是？",
      "max_score": 5,
      "student_answer": "80",
      "objective_rule": {
        "expected_answer": "80",
        "ignore_case": true,
        "trim_whitespace": true
      },
      "knowledge_tags": ["network", "http"]
    },
    {
      "question_id": "q-sub-1",
      "question_type": "subjective",
      "stem": "简述 RAG 标准流程。",
      "max_score": 10,
      "student_answer": "先检索再生成。",
      "subjective_rubric": [
        {"key": "retrieve", "description": "说明检索步骤", "score": 4},
        {"key": "rerank", "description": "说明重排步骤", "score": 2},
        {"key": "generate", "description": "说明生成步骤", "score": 4}
      ],
      "knowledge_tags": ["rag"]
    },
    {
      "question_id": "q-code-1",
      "question_type": "coding",
      "stem": "实现一个函数，返回输入数组的最大值。",
      "max_score": 15,
      "student_answer": "def max_num(nums):\n    return max(nums)",
      "coding_rubric": {
        "requirements": ["函数正确返回最大值", "考虑空数组情况"],
        "test_cases": ["[1,2,3] -> 3", "[] -> 合理异常或默认值"]
      },
      "knowledge_tags": ["python", "algorithm"]
    }
  ]
}

